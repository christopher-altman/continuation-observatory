DRY_RUN=false
DB_URL=sqlite:////opt/consciousness-observatory/data/observatory.db
SCHEDULER_TIMEZONE=UTC

# Comma-separated HTTPS origins allowed to call the live API.
CORS_ALLOWED_ORIGINS=https://continuationobservatory.org,https://www.continuationobservatory.org,https://consciousness-detector.ai,https://www.consciousness-detector.ai

# Required for POST /api/probes/trigger in live mode.
ADMIN_API_KEY=replace-with-a-random-secret
ADMIN_HEADER_NAME=x-admin-key

# Live startup is intentionally blocked unless you opt into SQLite explicitly.
ALLOW_LIVE_SQLITE=true
ALLOW_INSECURE_LIVE_CORS=false

# Provider credentials for enabled models in config/models.yaml.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
LLAMA_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=

# Only needed if you enable nova-premier.
AWS_BEARER_TOKEN_BEDROCK=
