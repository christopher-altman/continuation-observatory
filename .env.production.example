DRY_RUN=false
DB_URL=sqlite:////opt/continuation-observatory/data/observatory.db
SCHEDULER_TIMEZONE=UTC

# Comma-separated HTTPS origins allowed to call the live API.
CORS_ALLOWED_ORIGINS=https://continuationobservatory.org,https://www.continuationobservatory.org

# Required for POST /api/probes/trigger in live mode.
ADMIN_API_KEY=
ADMIN_HEADER_NAME=x-admin-key

# Live startup is intentionally blocked unless you opt into SQLite explicitly.
ALLOW_LIVE_SQLITE=true
ALLOW_INSECURE_LIVE_CORS=false

# Provider credentials for enabled models in config/models.yaml.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
