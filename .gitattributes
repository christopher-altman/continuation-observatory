# Normalize text files by default.
* text=auto

# Keep shipped source, docs, and bundle text files LF-normalized.
*.py text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.service text eol=lf
*.sh text eol=lf
CNAME text eol=lf

# Treat shipped image assets as binary.
*.png binary
*.ico binary
